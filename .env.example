# 关闭 Next.js 遥测。在部分 Windows/OneDrive 路径环境下,遥测写入配置文件会触发
# "EXDEV: cross-device link not permitted" 崩溃,关闭遥测可避免该问题。
NEXT_TELEMETRY_DISABLED=1

# ===== 应用基础配置 =====
# 线上可访问的完整域名(用于支付回调),本地开发可留空
APP_BASE_URL=http://localhost:3000

# 开发直通模式:true 时无需真实支付,下单后立即标记为已支付,方便本地调试
# 上线前请务必设置为 false,并配置好下方微信/支付宝商户信息
PAY_DEV_MODE=true

# ===== DeepSeek 大模型 API =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 价格配置(单位:分)=====
PRICE_BAZI_FEN=660
PRICE_MBTI_FEN=100
PRICE_TAROT_FEN=990
PRICE_PERSONALITY_FEN=500
PRICE_ASTROLOGY_FEN=500
PRICE_ZIWEI_FEN=300
PRICE_NUMEROLOGY_FEN=300
PRICE_BIGFIVE_FEN=500
PRICE_WORKSTYLE_FEN=500

# ===== 微信支付 v3(Native 扫码支付)=====
# 商户号
WECHAT_MCHID=
# 公众号/小程序/开放平台 AppID(APIv3 native 支付需要,可与商户号绑定的任意 appid)
WECHAT_APPID=
# APIv3 密钥(商户平台 -> API安全 中设置)
WECHAT_API_V3_KEY=
# 商户 API 证书序列号(命令: openssl x509 -in apiclient_cert.pem -noout -serial)
WECHAT_SERIAL_NO=
# 商户私钥文件内容(apiclient_key.pem 的完整文本,换行用 \n 表示)
WECHAT_PRIVATE_KEY=
# 商户证书文件内容(apiclient_cert.pem 的完整文本,换行用 \n 表示)
WECHAT_PUBLIC_CERT=

# ===== 支付宝(扫码支付/电脑网站支付)=====
ALIPAY_APP_ID=
# 应用私钥(PKCS1/PKCS8,完整文本,换行用 \n 表示)
ALIPAY_PRIVATE_KEY=
# 支付宝公钥(用于验签)
ALIPAY_PUBLIC_KEY=
